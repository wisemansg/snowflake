import streamlit as st
from datetime import datetime

# ====================== PAGE SETUP ======================
st.set_page_config(
    page_title="Hotel Analytics",
    page_icon="🏨",
    layout="wide"
)

st.title("🏨 Hotel Booking Analytics Dashboard")
st.markdown("**Performance Insights** • Streamlit in Snowflake")

if st.button("🔄 Refresh Data"):
    st.rerun()

# Snowflake Connection
conn = st.connection("snowflake")

# ====================== KEY PERFORMANCE INDICATORS ======================
st.subheader("📊 Key Performance Indicators")

col1, col2, col3, col4 = st.columns(4)

with col1:
    total_revenue = conn.query("""
        SELECT ROUND(SUM(total_amount), 2) AS value 
        FROM GOLD_BOOKING_CLEAN
    """).iloc[0, 0]
    st.metric(label="💰 Total Revenue", value=f"${total_revenue:,.0f}")

with col2:
    total_bookings = conn.query("""
        SELECT COUNT(*) AS value 
        FROM GOLD_BOOKING_CLEAN
    """).iloc[0, 0]
    st.metric(label="📅 Total Bookings", value=f"{total_bookings:,}")

with col3:
    total_guests = conn.query("""
        SELECT SUM(num_guests) AS value 
        FROM GOLD_BOOKING_CLEAN
    """).iloc[0, 0]
    st.metric(label="👥 Total Guests", value=f"{total_guests:,}")

with col4:
    avg_booking_value = conn.query("""
        SELECT ROUND(AVG(total_amount), 2) AS value 
        FROM GOLD_BOOKING_CLEAN
    """).iloc[0, 0]
    st.metric(label="💎 Avg Booking Value", value=f"${avg_booking_value:,.2f}")

st.divider()

# ====================== TABS WITH ICONS ======================
tab1, tab2, tab3 = st.tabs([
    "📈 Revenue Trends", 
    "🏙️ City Performance", 
    "🛏️ Booking Breakdown"
])

with tab1:
    st.subheader("📈 Monthly Revenue Trend")
    monthly_rev = conn.query("""
        SELECT 
            DATE_TRUNC('MONTH', check_in_date) AS month,
            ROUND(SUM(total_amount), 2) AS total_revenue
        FROM GOLD_BOOKING_CLEAN
        GROUP BY month
        ORDER BY month
    """)
    st.line_chart(monthly_rev, x="MONTH", y="TOTAL_REVENUE", use_container_width=True)

    st.subheader("📊 Monthly Bookings Trend")
    monthly_book = conn.query("""
        SELECT 
            DATE_TRUNC('MONTH', check_in_date) AS month,
            COUNT(*) AS total_bookings
        FROM GOLD_BOOKING_CLEAN
        GROUP BY month
        ORDER BY month
    """)
    st.line_chart(monthly_book, x="MONTH", y="TOTAL_BOOKINGS", use_container_width=True)

with tab2:
    st.subheader("🏆 Top Cities by Revenue")
    cities = conn.query("""
        SELECT 
            hotel_city,
            ROUND(SUM(total_amount), 2) AS total_revenue
        FROM GOLD_BOOKING_CLEAN
        GROUP BY hotel_city
        ORDER BY total_revenue DESC
        LIMIT 8
    """)
    st.bar_chart(cities, x="HOTEL_CITY", y="TOTAL_REVENUE", use_container_width=True)

with tab3:
    st.subheader("🛏️ Bookings by Room Type")
    rooms = conn.query("""
        SELECT 
            room_type,
            COUNT(*) AS total_bookings
        FROM GOLD_BOOKING_CLEAN
        GROUP BY room_type
        ORDER BY total_bookings DESC
    """)
    st.bar_chart(rooms, x="ROOM_TYPE", y="TOTAL_BOOKINGS", use_container_width=True)

    st.subheader("📌 Bookings by Status")
    status_df = conn.query("""
        SELECT 
            booking_status,
            COUNT(*) AS total_bookings
        FROM GOLD_BOOKING_CLEAN
        GROUP BY booking_status
    """)
    st.bar_chart(status_df, x="BOOKING_STATUS", y="TOTAL_BOOKINGS", use_container_width=True)

# Footer
st.caption("🏨 Hotel Booking Analytics Dashboard | Streamlit in Snowflake")
